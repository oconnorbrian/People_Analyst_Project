      <aliases enabled='yes' />
      <column caption='Absence Days' datatype='integer' name='[AbsenceDays]' role='measure' type='quantitative' />
      <column caption='Attrition Status' datatype='string' name='[AttritionStatus]' role='dimension' type='nominal' />
      <column datatype='real' default-format='p0.00%' name='[Calculation1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([PerformanceRating]) / TOTAL(SUM([PerformanceRating]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Performance Group' datatype='string' name='[Calculation_2775159228174337]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [PerformanceRating] &gt;= 4 THEN &quot;High Performer&quot;&#10;ELSEIF [PerformanceRating] &lt;= 2 THEN &quot;Low Performer&quot;&#10;ELSE &quot;Mid Performer&quot;&#10;END' />
      </column>
      <column caption='Talent Segment' datatype='string' name='[Calculation_2775159233609730]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [PerformanceRating] &gt;= 4 AND [EngagementScore] &lt; 50 THEN &#10;    &quot;High Performer - At Risk&quot;&#10;&#10;ELSEIF [PerformanceRating] &gt;= 4 AND [EngagementScore] &gt;= 75 THEN &#10;    &quot;High Performer - Engaged&quot;&#10;&#10;ELSEIF [PerformanceRating] &lt;= 2 AND [EngagementScore] &gt;= 50 THEN &#10;    &quot;Low Performer - Coachable&quot;&#10;&#10;ELSEIF [PerformanceRating] &lt;= 2 AND [EngagementScore] &lt; 50 THEN &#10;    &quot;Low Performer - Disengaged&quot;&#10;&#10;ELSE &#10;    &quot;Mid Performer&quot;&#10;END' />
      </column>
      <column caption='Overall Attrition Rate' datatype='real' name='[Calculation_2775159235530756]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [AttritionStatus] = &quot;Exited&quot; THEN 1 END)&#10;/ COUNT([EmployeeID])' />
      </column>
      <column caption='High Performer Retention' datatype='real' name='[Calculation_2775159235653637]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#10;    IF [PerformanceRating] &gt;= 4 &#10;    AND [AttritionStatus] = &quot;Active&quot;&#10;    THEN 1 END&#10;)&#10;/&#10;SUM(&#10;    IF [PerformanceRating] &gt;= 4 &#10;    THEN 1 END&#10;)' />
      </column>
      <column caption='Low Performance Exit Rate' datatype='real' name='[Calculation_2775159235829766]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#10;    IF [PerformanceRating] &lt;= 2 &#10;    AND [AttritionStatus] = &quot;Exited&quot;&#10;    THEN 1 END&#10;)&#10;/&#10;SUM(&#10;    IF [PerformanceRating] &lt;= 2 &#10;    THEN 1 END&#10;)' />
      </column>
      <column caption='Employee ID' datatype='string' name='[EmployeeID]' role='dimension' type='nominal' />
      <column caption='Engagement Score' datatype='integer' name='[EngagementScore]' role='measure' type='quantitative' />
      <column caption='Exit Type' datatype='string' name='[ExitType]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;N/A&quot;' value='Still Employed' />
        </aliases>
      </column>
      <column caption='Hire Date' datatype='date' name='[HireDate]' role='dimension' type='ordinal' />
      <column caption='Last Review Date' datatype='date' name='[LastReviewDate]' role='dimension' type='ordinal' />
      <column caption='Manager ID' datatype='string' name='[ManagerID]' role='dimension' type='nominal' />
      <column caption='Performance Rating' datatype='integer' default-format='n#,##0;-#,##0' name='[PerformanceRating]' role='measure' type='quantitative' />
      <column caption='Tenure Band' datatype='string' name='[TenureBand]' role='dimension' type='nominal'>
