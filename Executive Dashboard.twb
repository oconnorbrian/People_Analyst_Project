    <worksheet name='Overall Attrition Rate'>
      <table>
        <view>
          <datasources>
            <datasource caption='HR Data' name='federated.1xg4mg40dvahpz1e7pd131wxuzng' />
          </datasources>
          <datasource-dependencies datasource='federated.1xg4mg40dvahpz1e7pd131wxuzng'>
            <column caption='Attrition Status' datatype='string' name='[AttritionStatus]' role='dimension' type='nominal' />
            <column caption='Performance Group' datatype='string' name='[Calculation_2775159228174337]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [PerformanceRating] &gt;= 4 THEN &quot;High Performer&quot;&#10;ELSEIF [PerformanceRating] &lt;= 2 THEN &quot;Low Performer&quot;&#10;ELSE &quot;Mid Performer&quot;&#10;END' />
            </column>
            <column caption='Talent Segment' datatype='string' name='[Calculation_2775159233609730]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [PerformanceRating] &gt;= 4 AND [EngagementScore] &lt; 50 THEN &#10;    &quot;High Performer - At Risk&quot;&#10;&#10;ELSEIF [PerformanceRating] &gt;= 4 AND [EngagementScore] &gt;= 75 THEN &#10;    &quot;High Performer - Engaged&quot;&#10;&#10;ELSEIF [PerformanceRating] &lt;= 2 AND [EngagementScore] &gt;= 50 THEN &#10;    &quot;Low Performer - Coachable&quot;&#10;&#10;ELSEIF [PerformanceRating] &lt;= 2 AND [EngagementScore] &lt; 50 THEN &#10;    &quot;Low Performer - Disengaged&quot;&#10;&#10;ELSE &#10;    &quot;Mid Performer&quot;&#10;END' />
            </column>
            <column caption='Overall Attrition Rate' datatype='real' name='[Calculation_2775159235530756]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [AttritionStatus] = &quot;Exited&quot; THEN 1 END)&#10;/ COUNT([EmployeeID])' />
